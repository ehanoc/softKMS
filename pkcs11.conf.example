# softKMS PKCS#11 configuration
# 
# This file configures the PKCS#11 module (libsoftkms.so)
#
# Search order:
# 1. $SOFTKMS_PKCS11_CONFIG (environment variable)
# 2. $XDG_CONFIG_HOME/softkms/pkcs11.conf
# 3. ~/.config/softkms/pkcs11.conf
# 4. /etc/softkms/pkcs11.conf

# Daemon connection settings
daemon_addr = "127.0.0.1:50051"

# PKCS#11 token identification
slot_description = "softKMS"
token_label = "softKMS Token"

# Enable debug logging (for development only)
debug = false