# softKMS Configuration File
# Copy to /etc/softkms/config.toml and customize as needed

[storage]
# Storage backend type: "file" or "memory" (for testing)
backend = "file"
# Path to store encrypted keys and data
path = "/var/lib/softkms"

[storage.encryption]
# PBKDF2 iterations for master key derivation
# Higher = more secure but slower (210000 is recommended minimum)
pbkdf2_iterations = 210000
# Algorithm for key wrapping: "aes-256-gcm" or "chacha20poly1305"
algorithm = "aes-256-gcm"

[api]
# gRPC API address (for daemon)
grpc_addr = "127.0.0.1:50051"
# REST API address (for HTTP clients)
rest_addr = "127.0.0.1:8080"
# Enable PKCS#11 interface
enable_pkcs11 = true
# PKCS#11 library path (optional, for custom installs)
# pkcs11_path = "/usr/lib/softkms/libsoftkms.so"

[logging]
# Log level: "trace", "debug", "info", "warn", "error"
level = "info"
# Log destination: "stdout", "stderr", "file", "journal"
destination = "journal"
# Log file path (if destination = "file")
# file_path = "/var/log/softkms/softkms.log"
# Enable audit logging
enable_audit = true
# Audit log path
audit_path = "/var/log/softkms/audit"

[security]
# Session timeout in seconds (0 = no timeout)
session_timeout = 3600
# Maximum number of cached master keys
max_cached_keys = 10
# Auto-lock after inactivity (seconds, 0 = disabled)
auto_lock_seconds = 300

# Identity settings
[identity]
# Token validity period in seconds
token_validity = 86400
# Maximum identities per admin
max_identities = 100

# PKCS#11 settings
[pkcs11]
# Slot description for PKCS#11
slot_description = "softKMS Cryptographic Token"
# Token label
token_label = "softKMS"
# Token serial number (auto-generated if empty)
# serial_number = ""
